{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QueryMsg",
  "oneOf": [
    {
      "description": "Get a specific verification result by ID.",
      "type": "object",
      "required": [
        "verification_result"
      ],
      "properties": {
        "verification_result": {
          "type": "object",
          "required": [
            "verification_id"
          ],
          "properties": {
            "verification_id": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "List verification results for a subject.",
      "type": "object",
      "required": [
        "verifications_by_subject"
      ],
      "properties": {
        "verifications_by_subject": {
          "type": "object",
          "required": [
            "subject"
          ],
          "properties": {
            "limit": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint32",
              "minimum": 0.0
            },
            "start_after": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 0.0
            },
            "subject": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Get the current contract configuration.",
      "type": "object",
      "required": [
        "config"
      ],
      "properties": {
        "config": {
          "type": "object",
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}
