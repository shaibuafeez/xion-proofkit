              "dkim_signature",
              "email_domain",
              "email_headers",
              "issuer",
              "schema_id",
              "subject"
            ],
            "properties": {
              "dkim_signature": {
                "description": "DKIM signature data (base64-encoded).",
                "type": "string"
              },
              "email_domain": {
                "description": "The email domain to verify (e.g., \"company.com\").",
                "type": "string"
              },
              "email_headers": {
                "description": "The email headers used for DKIM verification.",
                "type": "string"
              },
              "expires_at": {
                "description": "Optional expiration for the proof record.",
                "type": [
                  "integer",
                  "null"
                ],
                "format": "uint64",
                "minimum": 0.0
              },
              "issuer": {
                "description": "The issuer who signed the credential.",
                "type": "string"
              },
              "schema_id": {
                "description": "The schema to verify against.",
                "type": "string"
              },
              "subject": {
                "description": "The subject whose credential is being verified.",
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      {
        "description": "Batch-verify multiple credentials in a single transaction.",
        "type": "object",
        "required": [
          "batch_verify"
