{
  "contract_name": "verifier",
  "contract_version": "0.1.0",
  "idl_version": "1.0.0",
  "instantiate": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "InstantiateMsg",
    "type": "object",
    "required": [
      "credential_registry",
      "issuer_registry"
    ],
    "properties": {
      "admin": {
        "description": "Optional admin address; defaults to the instantiator.",
        "type": [
          "string",
          "null"
        ]
      },
      "credential_registry": {
        "description": "Address of the credential registry contract for recording proofs.",
        "type": "string"
      },
      "issuer_registry": {
        "description": "Address of the issuer registry contract for authorization checks.",
        "type": "string"
      }
    },
    "additionalProperties": false
  },
  "execute": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ExecuteMsg",
    "oneOf": [
      {
        "description": "Verify a ZK credential proof via XION's ZK Module.",
        "type": "object",
        "required": [
          "verify_credential"
        ],
        "properties": {
          "verify_credential": {
            "type": "object",
            "required": [
              "issuer",
              "proof",
              "public_inputs",
              "schema_id",
              "subject"
            ],
            "properties": {
              "expires_at": {
                "description": "Optional expiration for the proof record.",
                "type": [
                  "integer",
                  "null"
                ],
                "format": "uint64",
                "minimum": 0.0
              },
              "issuer": {
                "description": "The issuer who signed the credential.",
                "type": "string"
              },
              "proof": {
                "description": "Raw ZK proof bytes (base64-encoded).",
                "type": "string"
              },
              "public_inputs": {
                "description": "Public inputs for the ZK verification (base64-encoded).",
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "schema_id": {
                "description": "The schema to verify against.",
                "type": "string"
              },
              "subject": {
                "description": "The subject whose credential is being verified.",
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      {
