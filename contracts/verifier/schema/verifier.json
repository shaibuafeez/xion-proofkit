            "properties": {
              "email_proof": {
                "type": "object",
                "required": [
                  "dkim_signature",
                  "email_domain",
                  "email_headers",
                  "issuer",
                  "schema_id",
                  "subject"
                ],
                "properties": {
                  "dkim_signature": {
                    "type": "string"
                  },
                  "email_domain": {
                    "type": "string"
                  },
                  "email_headers": {
                    "type": "string"
                  },
                  "expires_at": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "format": "uint64",
                    "minimum": 0.0
                  },
                  "issuer": {
                    "type": "string"
                  },
                  "schema_id": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
